# No required environment variables.
# JWT_SECRET is auto-generated on first startup and stored in the database.
#
# Optional overrides:
# JWT_SECRET=<string>       (default: auto-generated)
# DATABASE_URL=<url>         (default: file:./data/rss.db)
# PORT=<number>             (default: 3000)
# AUTH_DISABLED=1            (development only)
